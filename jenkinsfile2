pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                bat 'npm ci'
            }
        }

        stage('Install Browsers') {
            steps {
                bat 'npx playwright install'
            }
        }

        stage('Test') {
            steps {
                bat 'npx playwright test --list'
                bat 'npx playwright test'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying the Project..........'
            }
        }
    }
}